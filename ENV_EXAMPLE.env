# Tito Marlon Backend Environment

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1

# If backend runs directly on Windows:
# DATABASE_URL=postgresql+psycopg://titomarlon:CHANGE_ME@localhost:5432/titomarlon

# If backend runs in Docker on the same Windows host:
DATABASE_URL=postgresql+psycopg://titomarlon:CHANGE_ME@host.docker.internal:5432/titomarlon

APP_ENV=development
LOG_LEVEL=INFO

# Optional media generation/storage. Generated images must be hosted at a public HTTPS URL
# before Messenger can send them.
MEDIA_PUBLIC_BASE_URL=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional escalation notification target for "message John first" flows.
JOHN_NOTIFY_WEBHOOK_URL=
